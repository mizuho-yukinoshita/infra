# IntelliJ project files
.idea
*.iml
out
gen

# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# NOTE: .tfvars files are NOT ignored. This repository is a template collection
# and ships only sample.tfvars; when adopting a template for a real project,
# create <env>.tfvars (e.g. cp sample.tfvars dev.tfvars) and commit it.
# Never put secrets (passwords, private keys, tokens, etc.) in .tfvars;
# inject them via TF_VAR_* environment variables or AWS Secrets Manager instead.

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# Ignore tfplan files (the plan output of: terraform plan -out=tfplan)
*tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc

/config/*

!**/.gitkeep